# Copy to .env for local dev, and set these in Vercel → Project → Settings → Environment Variables.
# All are OPTIONAL: with none set, the app runs on the free Open-Meteo API with an
# in-memory (per-instance) cache. See README "Deploying to Vercel".

# --- Shared cache + rate limiter (recommended in production) ---
# Create a free Upstash Redis database and copy its REST credentials. The Vercel
# Marketplace Upstash integration injects these automatically — leave its "Custom Prefix"
# EMPTY. Vercel-KV-style names (KV_REST_API_URL / KV_REST_API_TOKEN) are also accepted.
# NOTE: read at BUILD time — set them before deploying, and redeploy if you add them later.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Open-Meteo User-Agent contact (recommended: a role address, not personal) ---
NUXT_OPEN_METEO_CONTACT=ops@example.com

# --- Weather-data licensing (leave unset for the free non-commercial tier) ---
# Commercial plan (auto-switches to the customer endpoint):
# NUXT_OPEN_METEO_API_KEY=
# Self-hosted Open-Meteo instance:
# NUXT_OPEN_METEO_BASE_URL=
